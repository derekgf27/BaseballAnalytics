# Copy this file to .env.local and fill in your Supabase values.
# Get them from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — required for Admin → User profiles (create/delete users). Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Production site URL (used by Supabase Auth redirect validation). Set in Vercel env.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: comma-separated emails allowed to sign in (empty = any authenticated user).
# ALLOWED_EMAILS=you@team.com

# Login is OFF by default (open app). Set to true when you want sign-in + role-based routes (e.g. production).
# AUTH_REQUIRED=true
# After AUTH_REQUIRED=true, run supabase/migrations/20260608_profiles_roles.sql and set roles in public.profiles.
# Emergency: keep app open even if AUTH_REQUIRED=true (rare).
# AUTH_DISABLED=true

# Optional: your club name for new games (skips re-typing on Add game). If unset, the app uses your club name from the latest game.
# NEXT_PUBLIC_CLUB_TEAM_NAME=Reyes de Juana Diaz

# Regulation game length in innings (default 7). Drives ERA, K/7-style rates, linescore width, and Record inning advance.
# NEXT_PUBLIC_REGULATION_INNINGS=7
