# Copy this file to .env.local and fill in your Supabase values.
# Get them from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Production site URL (used by Supabase Auth redirect validation). Set in Vercel env.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: comma-separated emails allowed to sign in (empty = any authenticated user).
# ALLOWED_EMAILS=you@team.com

# Login is OFF by default (open app). Set to true when you want Google sign-in + protected routes (e.g. production).
# AUTH_REQUIRED=true
# Emergency: keep app open even if AUTH_REQUIRED=true (rare).
# AUTH_DISABLED=true
